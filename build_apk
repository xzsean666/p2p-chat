#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}"

DEFAULT_KEYSTORE_PATH="${PROJECT_ROOT}/.local/android-upload.keystore"
DEFAULT_KEY_ALIAS="upload"
DEFAULT_RELEASE_DIR="${PROJECT_ROOT}/release"
DEFAULT_BUILD_TARGET="aarch64"

KEYSTORE_PATH="${ANDROID_KEYSTORE_PATH:-${TAURI_ANDROID_KEYSTORE_PATH:-$DEFAULT_KEYSTORE_PATH}}"
KEY_ALIAS="${ANDROID_KEY_ALIAS:-${TAURI_ANDROID_KEY_ALIAS:-$DEFAULT_KEY_ALIAS}}"
RELEASE_DIR="${ANDROID_RELEASE_DIR:-$DEFAULT_RELEASE_DIR}"
BUILD_TARGET="${ANDROID_BUILD_TARGET:-$DEFAULT_BUILD_TARGET}"
STORE_PASSWORD="${ANDROID_KEYSTORE_PASSWORD:-${TAURI_ANDROID_KEYSTORE_PASSWORD:-}}"
KEY_PASSWORD="${ANDROID_KEY_PASSWORD:-${TAURI_ANDROID_KEY_PASSWORD:-}}"
TMP_DIR=""

usage() {
  cat <<'EOF'
Usage:
  bash ./build_apk [options]

Options:
  --target TARGET       Android build target, default: aarch64
  --release-dir PATH    Directory to copy the final APK into
  --help                Show this help

Environment variables:
  ANDROID_KEYSTORE_PATH
  ANDROID_KEY_ALIAS
  ANDROID_KEYSTORE_PASSWORD
  ANDROID_KEY_PASSWORD
  ANDROID_RELEASE_DIR
  ANDROID_BUILD_TARGET
EOF
}

resolve_android_sdk_root() {
  local candidate=""

  if [[ -n "${ANDROID_SDK_ROOT:-}" && -d "${ANDROID_SDK_ROOT}" ]]; then
    candidate="${ANDROID_SDK_ROOT}"
  elif [[ -n "${ANDROID_HOME:-}" && -d "${ANDROID_HOME}" ]]; then
    candidate="${ANDROID_HOME}"
  elif [[ -d "${HOME}/Android/Sdk" ]]; then
    candidate="${HOME}/Android/Sdk"
  fi

  [[ -n "${candidate}" ]] || return 1

  export ANDROID_HOME="${candidate}"
  export ANDROID_SDK_ROOT="${candidate}"
}

find_android_build_tool() {
  local tool_name="$1"
  local latest=""
  local candidate=""

  if command -v "${tool_name}" >/dev/null 2>&1; then
    command -v "${tool_name}"
    return 0
  fi

  resolve_android_sdk_root || return 1
  [[ -d "${ANDROID_SDK_ROOT}/build-tools" ]] || return 1

  while IFS= read -r candidate; do
    [[ -x "${candidate}" ]] || continue
    latest="${candidate}"
  done < <(find "${ANDROID_SDK_ROOT}/build-tools" -mindepth 2 -maxdepth 2 -type f -name "${tool_name}" | sort -V)

  [[ -n "${latest}" ]] || return 1
  printf '%s\n' "${latest}"
}

find_latest_apk() {
  local mode="$1"
  local find_expr=()

  case "${mode}" in
    signed)
      find_expr=(-name '*.apk' ! -name '*unsigned.apk')
      ;;
    unsigned)
      find_expr=(-name '*unsigned.apk')
      ;;
    *)
      printf 'Unsupported APK search mode: %s\n' "${mode}" >&2
      exit 1
      ;;
  esac

  find "${PROJECT_ROOT}/src-tauri/gen/android/app/build/outputs/apk" -type f "${find_expr[@]}" -printf '%T@ %p\n' \
    | sort -nr \
    | head -n 1 \
    | cut -d' ' -f2-
}

sign_unsigned_apk() {
  local unsigned_apk="$1"
  local signed_apk="$2"
  local zipalign_bin="$3"
  local apksigner_bin="$4"
  local aligned_apk="${TMP_DIR}/aligned.apk"

  "${zipalign_bin}" -f -p 4 "${unsigned_apk}" "${aligned_apk}"
  "${apksigner_bin}" sign \
    --ks "${KEYSTORE_PATH}" \
    --ks-key-alias "${KEY_ALIAS}" \
    --ks-pass "pass:${STORE_PASSWORD}" \
    --key-pass "pass:${KEY_PASSWORD}" \
    --out "${signed_apk}" \
    "${aligned_apk}"
  "${apksigner_bin}" verify "${signed_apk}" >/dev/null
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      ;;
    --target)
      BUILD_TARGET="$2"
      shift 2
      ;;
    --release-dir)
      RELEASE_DIR="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if ! command -v node >/dev/null 2>&1; then
  printf 'node not found in PATH\n' >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  printf 'pnpm not found in PATH\n' >&2
  exit 1
fi

if ! command -v sha256sum >/dev/null 2>&1; then
  printf 'sha256sum not found in PATH\n' >&2
  exit 1
fi

cleanup() {
  if [[ -n "${TMP_DIR}" && -d "${TMP_DIR}" ]]; then
    rm -rf "${TMP_DIR}"
  fi
}

trap cleanup EXIT

APP_NAME="$(
  node -e 'const fs=require("fs"); const pkg=JSON.parse(fs.readFileSync(process.argv[1], "utf8")); console.log((pkg.name || "app").replace(/[^A-Za-z0-9._-]+/g, "-"));' \
    "${PROJECT_ROOT}/package.json"
)"
APP_VERSION="$(
  node -e 'const fs=require("fs"); const pkg=JSON.parse(fs.readFileSync(process.argv[1], "utf8")); console.log((pkg.version || "0.0.0").replace(/[^A-Za-z0-9._-]+/g, "-"));' \
    "${PROJECT_ROOT}/package.json"
)"

if [[ -z "${STORE_PASSWORD}" ]]; then
  read -r -s -p "Keystore password: " STORE_PASSWORD
  printf '\n'
fi

if [[ -z "${KEY_PASSWORD}" ]]; then
  read -r -s -p "Key password (press Enter to reuse keystore password): " KEY_PASSWORD
  printf '\n'
  if [[ -z "${KEY_PASSWORD}" ]]; then
    KEY_PASSWORD="${STORE_PASSWORD}"
  fi
fi

if [[ ! -f "${KEYSTORE_PATH}" ]]; then
  printf 'Keystore not found. Creating: %s\n' "${KEYSTORE_PATH}"
  ANDROID_KEYSTORE_PATH="${KEYSTORE_PATH}" \
  ANDROID_KEY_ALIAS="${KEY_ALIAS}" \
  ANDROID_KEYSTORE_PASSWORD="${STORE_PASSWORD}" \
  ANDROID_KEY_PASSWORD="${KEY_PASSWORD}" \
    bash "${PROJECT_ROOT}/scripts/generate-android-keystore.sh" --out "${KEYSTORE_PATH}" --alias "${KEY_ALIAS}"
fi

TARGET_LABEL="arm64"
case "${BUILD_TARGET}" in
  aarch64) TARGET_LABEL="arm64" ;;
  armv7) TARGET_LABEL="armv7" ;;
  i686) TARGET_LABEL="x86" ;;
  x86_64) TARGET_LABEL="x86_64" ;;
  *) TARGET_LABEL="${BUILD_TARGET}" ;;
esac

ANDROID_KEYSTORE_PATH="${KEYSTORE_PATH}" \
ANDROID_KEY_ALIAS="${KEY_ALIAS}" \
ANDROID_KEYSTORE_PASSWORD="${STORE_PASSWORD}" \
ANDROID_KEY_PASSWORD="${KEY_PASSWORD}" \
TAURI_ANDROID_KEYSTORE_PATH="${KEYSTORE_PATH}" \
TAURI_ANDROID_KEYSTORE="${KEYSTORE_PATH}" \
TAURI_ANDROID_KEY_ALIAS="${KEY_ALIAS}" \
TAURI_ANDROID_KEYSTORE_PASSWORD="${STORE_PASSWORD}" \
TAURI_ANDROID_KEY_PASSWORD="${KEY_PASSWORD}" \
  bash "${PROJECT_ROOT}/scripts/build-android-apk.sh" --apk --target "${BUILD_TARGET}"

mkdir -p "${RELEASE_DIR}"

FINAL_APK="${RELEASE_DIR}/${APP_NAME}-v${APP_VERSION}-android-${TARGET_LABEL}-release.apk"
LATEST_APK="${RELEASE_DIR}/${APP_NAME}-android-release.apk"
SIGNED_APK="$(find_latest_apk signed)"
UNSIGNED_APK="$(find_latest_apk unsigned)"
NEEDS_POST_SIGN=0

if [[ -z "${SIGNED_APK}" || ! -f "${SIGNED_APK}" ]]; then
  NEEDS_POST_SIGN=1
elif [[ -n "${UNSIGNED_APK}" && -f "${UNSIGNED_APK}" && "${UNSIGNED_APK}" -nt "${SIGNED_APK}" ]]; then
  NEEDS_POST_SIGN=1
fi

if (( NEEDS_POST_SIGN == 1 )); then
  if [[ -z "${UNSIGNED_APK}" || ! -f "${UNSIGNED_APK}" ]]; then
    printf 'No APK artifact found after build\n' >&2
    exit 1
  fi

  ZIPALIGN_BIN="$(find_android_build_tool zipalign || true)"
  APKSIGNER_BIN="$(find_android_build_tool apksigner || true)"

  if [[ -z "${ZIPALIGN_BIN}" || -z "${APKSIGNER_BIN}" ]]; then
    printf 'Signed APK not found after build, and zipalign/apksigner were not found under Android SDK build-tools\n' >&2
    exit 1
  fi

  TMP_DIR="$(mktemp -d "${RELEASE_DIR}/.android-sign.XXXXXX")"
  SIGNED_APK="${TMP_DIR}/signed.apk"

  printf 'Newest APK artifact is unsigned; signing it with local keystore:\n'
  printf '  %s\n' "${UNSIGNED_APK}"
  sign_unsigned_apk "${UNSIGNED_APK}" "${SIGNED_APK}" "${ZIPALIGN_BIN}" "${APKSIGNER_BIN}"
fi

cp -f "${SIGNED_APK}" "${FINAL_APK}"
cp -f "${FINAL_APK}" "${LATEST_APK}"

printf '\nFinal APK:\n'
printf '  %s\n' "${FINAL_APK}"
printf 'Latest copy:\n'
printf '  %s\n' "${LATEST_APK}"
printf 'SHA256:\n'
sha256sum "${FINAL_APK}"
