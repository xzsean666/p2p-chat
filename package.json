{
  "name": "p2p-chat",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "description": "P2P chat desktop rebuild powered by Tauri 2, Rust, Vue 3 and PrimeVue.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "check": "vue-tsc --noEmit",
    "runtime:build:dev": "cargo build --manifest-path src-tauri/Cargo.toml --bin p2p-chat-runtime",
    "runtime:build:release": "cargo build --manifest-path src-tauri/Cargo.toml --bin p2p-chat-runtime --release",
    "version:check": "node scripts/version-sync.mjs check",
    "version:set": "node scripts/version-sync.mjs set",
    "native:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "native:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify": "pnpm version:check && pnpm build && pnpm native:test",
    "desktop:build": "pnpm verify && pnpm tauri build -b deb,rpm",
    "desktop:build:full": "pnpm verify && pnpm tauri build",
    "android:deps": "bash scripts/install-android-build-deps.sh",
    "android:init": "pnpm tauri android init --ci --skip-targets-install",
    "android:keystore": "bash scripts/generate-android-keystore.sh",
    "android:apk": "bash scripts/build-android-apk.sh",
    "android:release": "bash ./build_apk",
    "release:linux": "pnpm desktop:build && node scripts/collect-linux-release.mjs",
    "release:collect": "node scripts/collect-linux-release.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "jsqr": "^1.4.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
